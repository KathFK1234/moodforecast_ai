# WeatherAI API Configuration
WEATHERAI_API_KEY=your_api_key_here

# Database Configuration
DATABASE_URL=sqlite:///./moodforecast.db

# Optional: Redis Cache (if not set, uses in-memory cache)
# REDIS_URL=redis://localhost:6379/0

# Cache TTL in seconds (default: 600 = 10 minutes)
CACHE_TTL_SECONDS=600

# Environment
ENVIRONMENT=development
